# 🔒 Database Connection (TEMPLATE)
ConnectionStrings__DefaultConnection="Server=YOUR_SERVER;Database=TechShopDb;User=YOUR_USER;Password=YOUR_PASSWORD;..."

# 🌐 CORS Configuration (TEMPLATE)
ALLOWED_ORIGINS="http://localhost:5173"

# 🔑 Authentication (TEMPLATE)
Jwt__Key="YOUR_32_CHARACTER_LONG_SECRET_KEY_HERE"
Jwt__Issuer="TechShopAPI"
Jwt__Audience="TechShopFrontend"

# ☁️ Cloudinary Configuration (TEMPLATE)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
